# Environment: dev | staging | prod. Defaults to dev.
# In prod, /api/demo/* and /api/operator/* refuse to mount, the SPA hides the
# Demo/Operator nav items, and the server refuses to start if any tenant has
# sandbox.enabled=true.
APP_ENV=dev

# Sandbox redirect targets — sandboxed outbound (email/SMS/voice) is rewritten
# to these recipients so it lands in your own inbox/phone during testing.
# Required when any tenant has sandbox.enabled=true (acme-test, northwind-health
# do by default). If unset, the server warns at startup and refuses to send
# rather than leak to the original recipient.
SANDBOX_EMAIL=
SANDBOX_PHONE=

ANTHROPIC_API_KEY=sk-ant-...

# Composio MCP server URL (create a custom MCP server in the Composio
# dashboard with the toolkits you want: apollo, linkedin, hubspot, gmail,
# clearbit, etc. Then copy the generated URL here.)
# Format: https://backend.composio.dev/v3/mcp/<SERVER_ID>?user_id=<USER_ID>
COMPOSIO_MCP_URL=
COMPOSIO_API_KEY=
# OPTIONAL but recommended — a Composio Developer API key (different from the
# ck_* Consumer key above). Needed for server-side SDK calls (e.g. BDR's
# Gmail send path). Dashboard: Developers / API Keys section.
COMPOSIO_SDK_API_KEY=

# mem0 platform
MEM0_API_KEY=

# Supabase project (service role key recommended for server-side writes)
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=

# Langfuse (OPTIONAL) — per-run agent traces + cost attribution.
# Free tier: https://cloud.langfuse.com. Leave empty to skip tracing (no-op).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Twilio (OPTIONAL) — for real SMS outbound.
# Skip these and send_sms will log "skipped: not configured" instead of firing.
# Free trial gives ~$15 credit (~200 SMS). Get creds at console.twilio.com.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Shared secret for POST /api/webhooks/inbound. Set any long random string.
# Sender must include it as `X-Webhook-Secret: ...`. Leave empty to disable.
PLATFORM_WEBHOOK_SECRET=

# Stytch — agent-to-agent auth + future human auth (Phase 5 Web UI).
# Project creds (required for Phase 1 agent tokens, signed HS256):
STYTCH_PROJECT_ID=
STYTCH_SECRET=
# OPTIONAL: M2M client creds to switch from local HS256 to native Stytch
# M2M agent tokens. Create via Stytch dashboard → B2B → M2M Clients.
STYTCH_M2M_CLIENT_ID=
STYTCH_M2M_CLIENT_SECRET=
