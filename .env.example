# Client-side (Vite) — safe to expose in bundle
VITE_STYTCH_PUBLIC_TOKEN=public-token-test-xxxxxxxx
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxx
VITE_APP_URL=http://localhost:5173

# Server-side — never prefix with VITE_
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
FIRECRAWL_API_KEY=
APIFY_API_TOKEN=
# Optional: override Apify Reddit scraper actor slug (default: trudax~reddit-scraper-lite)
# APIFY_REDDIT_ACTOR=trudax~reddit-scraper-lite
Resend_API=

# Stytch backend SDK — REQUIRED for /api/email, /api/firecrawl-search, /api/apify-reddit
STYTCH_PROJECT_ID=project-test-xxxxxxxx
STYTCH_SECRET=secret-test-xxxxxxxx
STYTCH_ENV=test

# Optional HTTP Basic Auth
# ADMIN_USER=
# ADMIN_PASS=
